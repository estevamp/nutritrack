```gitignore
# Dependencies
node_modules/

# Build artifacts
dist/
build/
*.js.map
*.tsbuildinfo

# Environment
.env
.env.local
.env.*

# Editors
.vscode/
.idea/
*.swp
*.swo
*.tmp

# Logs
*.log

# Python (if applicable)
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
.coverage
htmlcov/
.coverage.*
.pytest_cache/
.mypy_cache/

# Node.js (if applicable)
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS generated files
.DS_Store
Thumbs.db

# Coverage directory used by tools like istanbul
coverage/
```